# Python cache files
__pycache__/
*.py[cod]
*$py.class
*.pyc

# Virtual environment
.venv/
venv/
ENV/

# Environment secrets - NEVER include in Docker image
.env
.env.*

# IDE and editor files
.vscode/
.idea/
*.swp

# Testing artefacts
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# Git metadata - not needed in container
.git/
.gitignore

# OS generated files
.DS_Store
Thumbs.db

# Build artefacts
dist/
build/
